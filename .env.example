# Postgres
POSTGRES_USER=appuser
POSTGRES_PASSWORD=secret
POSTGRES_DB=semantic

# Embeddings: "local" runs all-MiniLM-L6-v2 with no API key needed
EMBEDDING_PROVIDER=local

# Optional: enables the /ask RAG endpoint with Claude-generated answers.
# Without it, /search still works as pure semantic search.
ANTHROPIC_API_KEY=
